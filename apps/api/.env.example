# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://user:password@localhost:5432/openroad

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_BUCKET=open-road-photos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Claude API (AI classification)
CLAUDE_API_KEY=sk-ant-...

# Cloudflare Images
CF_IMAGES_BASE_URL=https://imagedelivery.net/<account_hash>
CF_ACCOUNT_ID=<cloudflare_account_id>
CF_IMAGES_API_TOKEN=<cf_images_api_token>
# Get CF_IMAGES_API_TOKEN from: Cloudflare Dashboard → My Profile → API Tokens → Create Token → Cloudflare Images (Read & Write)

# App
WEB_URL=http://localhost:3000
MOBILE_SCHEME=openroad://
NODE_ENV=development
PORT=3001
