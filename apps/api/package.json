{
  "name": "@open-road/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "oxlint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@open-road/types": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/cors": "^10.0.0",
    "zod": "^4.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/adapter-ppg": "^7.0.0",
    "ioredis": "^5.4.0",
    "bullmq": "^5.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "sharp": "^0.33.0",
    "prisma": "^7.0.0",
    "@clerk/fastify": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "@open-road/config": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "dotenv": "^16.0.0",
    "oxlint": "^0.16.0",
    "vitest": "^3.0.0",
    "@types/sharp": "^0.31.0"
  }
}
